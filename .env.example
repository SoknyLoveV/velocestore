# Flask Configuration
# Generate a secure secret key for session cookie signing
FLASK_SECRET_KEY=your_secure_secret_key_here

# Telegram Bot API Configuration (Required for order notifications)
# Create a bot using BotFather on Telegram to get your token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Get your Chat ID (or Group Chat ID) where order notifications should be sent
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
